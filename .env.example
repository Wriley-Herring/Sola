# Public app URL used to build auth callback links (do not leave as localhost in production)
SITE_URL="http://localhost:3000"

# Supabase client/browser auth config
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Supabase server/admin config
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# OpenAI API key for insight generation (server-only)
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Optional Postgres URLs for bootstrap scripts
POSTGRES_URL_NON_POOLING="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"
POSTGRES_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres"
POSTGRES_PRISMA_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true&connect_timeout=15"

# Optional post-deploy health URL used by npm run verify
HEALTHCHECK_URL="http://localhost:3000/api/health"
