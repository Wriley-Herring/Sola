# Canonical app URL used to generate auth callback URLs
# (use your real domain in production)
SITE_URL="http://localhost:3000"

# Supabase public client config (browser + cookie-backed server auth client)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Supabase server admin config (service role client)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# OpenAI API key for server-side insight generation
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Optional DB connection URLs for manual SQL/admin workflows
# Preferred direct connection for psql:
POSTGRES_URL_NON_POOLING="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"
# Pooled connection:
POSTGRES_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres"
# Legacy Vercel-provided variable name; still accepted by helper code:
POSTGRES_PRISMA_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true&connect_timeout=15"

# Optional post-deploy health URL used by npm run verify:health
HEALTHCHECK_URL="http://localhost:3000/api/health"
