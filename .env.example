# Public app URL used to build auth callback links (do not leave as localhost in production)
SITE_URL="http://localhost:3000"

# Supabase project URL (safe for client/server)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase publishable key (safe for client usage)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# Direct Postgres connection string used to apply supabase/schema.sql + supabase/seed.sql during build/deploy
SUPABASE_DB_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# OpenAI API key for insight generation (server-only)
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Optional post-deploy health URL used by npm run verify
HEALTHCHECK_URL="http://localhost:3000/api/health"
