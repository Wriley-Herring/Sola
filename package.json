{
  "name": "sola",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration tests/middleware tests/actions",
    "test:e2e": "playwright test",
    "test:ci": "vitest run --coverage",
    "verify": "npm run verify:env && npm run lint && npm run typecheck && npm run test:unit && npm run test:integration && npm run verify:health",
    "db:bootstrap": "node scripts/bootstrap-db.mjs",
    "verify:env": "node scripts/verify-env.mjs",
    "verify:health": "node scripts/check-health.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@supabase/supabase-js": "^2.49.1",
    "clsx": "^2.1.1",
    "next": "14.2.18",
    "openai": "^4.86.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@supabase/ssr": "^0.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "@playwright/test": "^1.50.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/jest-dom": "^6.6.3"
  }
}
